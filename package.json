{
  "name": "yuiju",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "lint": "biome lint . --diagnostic-level=error",
    "format:write": "biome format . --write",
    "demo:message": "pnpm --filter @yuiju/message run demo",
    "demo:world": "pnpm --filter @yuiju/world run demo",
    "start:message": "pnpm --filter @yuiju/message run start",
    "start:world": "pnpm --filter @yuiju/world run start",
    "start:web": "pnpm --filter @yuiju/web run start",
    "start:python": "cd packages/python && uv run uvicorn server:app --host 0.0.0.0 --port 9196",
    "build:web": "pnpm --filter @yuiju/web run build",
    "dev:message": "pnpm --filter @yuiju/message run dev",
    "dev:world": "pnpm --filter @yuiju/world run dev",
    "dev:web": "pnpm --filter @yuiju/web run dev",
    "test:world": "pnpm --filter @yuiju/world run test",
    "type-check:world": "pnpm --filter @yuiju/world run type-check",
    "type-check:message": "pnpm --filter @yuiju/message run type-check",
    "type-check:utils": "pnpm --filter @yuiju/utils run type-check",
    "type-check": "pnpm run type-check:world && pnpm run type-check:message && pnpm run type-check:utils"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yixiaojiu/yuiju.git"
  },
  "keywords": [],
  "author": "",
  "license": "AGPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/yixiaojiu/yuiju/issues"
  },
  "homepage": "https://github.com/yixiaojiu/yuiju#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.3.5",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.10.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.13"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.1",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@types/mongoose": "^5.11.97",
    "ai": "^6.0.116",
    "bullmq": "^5.66.2",
    "dayjs": "^1.11.19",
    "dotenv": "^16.6.1",
    "ioredis": "^5.8.2",
    "lodash-es": "^4.17.21",
    "mem0ai": "^2.2.1",
    "mongoose": "^8.20.0",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.1.13"
  }
}
